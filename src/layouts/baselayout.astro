---
import "../styles/global.css";

interface Props {
  title?: string;
  lang?: string;
}

const { title = "ARIA STEAMEX", lang = "es" } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Equipo femenil FRC de Ciudad de México. Ingeniería, liderazgo e impacto STEM." />
</head>

<body>
  <slot />
</body>
</html>
