---
// src/pages/first.astro

import BaseLayout from "../layouts/baselayout.astro";
import Navbar from "../components/navbar.astro";
---

<BaseLayout title="FIRST / FRC | ARIA STEAMEX">

  <Navbar />

  <main class="overflow-hidden">

    <!-- HERO -->
    <section class="container-site pt-28 pb-24 text-center relative overflow-hidden">

      <div class="glow-orb w-56 h-56 bg-purple-400/20 top-10 right-20"></div>
      <div class="glow-orb w-40 h-40 bg-pink-300/10 bottom-0 left-10"></div>

      <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-6 reveal show">
        FIRST Robotics Competition
      </p>

      <h1 class="text-6xl md:text-8xl max-w-5xl mx-auto leading-none mb-8 reveal show">
        Mucho más que robots
      </h1>

      <p class="text-xl text-white/70 max-w-3xl mx-auto leading-relaxed mb-10 reveal show">
        FIRST combina ingeniería, estrategia, negocios y trabajo en equipo en una de las experiencias estudiantiles más prestigiosas del mundo.
      </p>

      <div class="flex flex-wrap justify-center gap-8 text-sm text-white/70 reveal show">

        <div>
          <strong class="block text-white text-xl">Global</strong>
          Comunidad internacional
        </div>

        <div>
          <strong class="block text-white text-xl">STEAM</strong>
          Educación aplicada
        </div>

        <div>
          <strong class="block text-white text-xl">Impacto</strong>
          Liderazgo juvenil
        </div>

        <div>
          <strong class="block text-white text-xl">FRC</strong>
          Nivel élite
        </div>

      </div>

    </section>

    <!-- WHAT IS FIRST -->
    <section class="container-site pb-28">

      <div class="mb-10 reveal">
        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
          Qué es FIRST
        </p>

        <h2 class="text-5xl leading-none">
          Una plataforma para crecer
        </h2>
      </div>

      <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6">

  <div class="glass rounded-3xl p-6 min-h-[170px] reveal">
    <h3 class="text-2xl mb-4">Mecánica</h3>
    <p class="text-white/65">
      Diseño, ensamblaje y sistemas físicos del robot.
    </p>
  </div>

  <div class="glass rounded-3xl p-6 min-h-[170px] reveal delay-1">
    <h3 class="text-2xl mb-4">Programación</h3>
    <p class="text-white/65">
      Código, sensores, automatización y control del robot.
    </p>
  </div>

  <div class="glass rounded-3xl p-6 min-h-[170px] reveal delay-2">
    <h3 class="text-2xl mb-4">Electrónica</h3>
    <p class="text-white/65">
      Cableado, energía, integración y sistemas eléctricos.
    </p>
  </div>

  <div class="glass rounded-3xl p-6 min-h-[170px] reveal delay-3">
    <h3 class="text-2xl mb-4">Negocios</h3>
    <p class="text-white/65">
      Sponsors, presupuesto y estrategia financiera.
    </p>
  </div>

  <div class="glass rounded-3xl p-6 min-h-[170px] reveal">
    <h3 class="text-2xl mb-4">Liderazgo</h3>
    <p class="text-white/65">
      Organización, comunicación y dirección del equipo.
    </p>
  </div>

  <div class="glass rounded-3xl p-6 min-h-[170px] reveal delay-1">
    <h3 class="text-2xl mb-4">Operaciones</h3>
    <p class="text-white/65">
      Planeación, logística y coordinación general.
    </p>
  </div>

  <div class="glass rounded-3xl p-6 min-h-[170px] reveal delay-2">
    <h3 class="text-2xl mb-4">Imagen</h3>
    <p class="text-white/65">
      Branding, redes sociales, contenido y presencia pública.
    </p>
  </div>

  <div class="glass rounded-3xl p-6 min-h-[170px] reveal delay-3">
    <h3 class="text-2xl mb-4">Impacto</h3>
    <p class="text-white/65">
      Outreach, comunidad y promoción de STEM.
    </p>
  </div>

</div>
    </section>

    <!-- WHAT IS FRC -->

<section class="container-site pb-28 reveal">

  <div class="rounded-3xl border border-white/10 glass p-10 md:p-14 relative overflow-hidden">

    <div class="glow-orb w-44 h-44 bg-purple-400/10 top-0 right-10"></div>

    <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-5">
      Qué es FRC
    </p>

    <h2 class="text-5xl md:text-7xl leading-none mb-8 max-w-4xl">
      La experiencia estudiantil más intensa en robótica
    </h2>

    <p class="text-white/72 text-lg max-w-3xl leading-relaxed mb-10">
      FIRST Robotics Competition reta a estudiantes a diseñar,
      fabricar y programar robots de alto rendimiento para competir
      cada año en un nuevo juego oficial junto a miles de equipos del mundo.
    </p>

    <div class="flex flex-wrap gap-4 mb-10">

  <div class="glass rounded-3xl px-6 py-4 w-[220px]">
    <p class="text-4xl leading-none mb-1">6+</p>
    <p class="text-white/60 text-sm">Semanas de build season</p>
  </div>

  <div class="glass rounded-3xl px-6 py-4 w-[220px]">
    <p class="text-4xl leading-none mb-1">1</p>
    <p class="text-white/60 text-sm">Juego nuevo anual</p>
  </div>

  <div class="glass rounded-3xl px-6 py-4 w-[220px]">
    <p class="text-4xl leading-none mb-1">Global</p>
    <p class="text-white/60 text-sm">Comunidad internacional</p>
  </div>

  <div class="glass rounded-3xl px-6 py-4 w-[220px]">
    <p class="text-4xl leading-none mb-1">Real</p>
    <p class="text-white/60 text-sm">Ingeniería aplicada</p>
  </div>

  <div class="flex flex-wrap gap-4 ">

      <a
        href="https://www.firstinspires.org"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary my-4"
      >
        Sitio oficial de FIRST
      </a>

      <a href="/unirse" class="btn-secondary my-4">
        Vivirlo con ARIA
      </a>

    </div>

</section>
    <!-- WHAT YOU LEARN -->
    <section class="container-site pb-28">

      <div class="mb-10 reveal">
        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
          Lo que aprendes
        </p>

        <h2 class="text-5xl leading-none">
          Mucho más que competir
        </h2>
      </div>

      <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-6">

        <div class="glass rounded-3xl p-7 reveal">
          <h3 class="text-3xl mb-4">CAD</h3>
          <p class="text-white/65">Diseño mecánico profesional.</p>
        </div>

        <div class="glass rounded-3xl p-7 reveal delay-1">
          <h3 class="text-3xl mb-4">Manufactura</h3>
          <p class="text-white/65">Procesos reales y fabricación.</p>
        </div>

        <div class="glass rounded-3xl p-7 reveal delay-2">
          <h3 class="text-3xl mb-4">Code</h3>
          <p class="text-white/65">Software para sistemas físicos.</p>
        </div>

        <div class="glass rounded-3xl p-7 reveal">
          <h3 class="text-3xl mb-4">Marketing</h3>
          <p class="text-white/65">Marca, redes y narrativa.</p>
        </div>

        <div class="glass rounded-3xl p-7 reveal delay-1">
          <h3 class="text-3xl mb-4">Negocios</h3>
          <p class="text-white/65">Relación con aliados y sponsors.</p>
        </div>

        <div class="glass rounded-3xl p-7 reveal delay-2">
          <h3 class="text-3xl mb-4">Liderazgo</h3>
          <p class="text-white/65">Organización y toma de decisiones.</p>
        </div>

      </div>

    </section>

    <!-- CTA -->
    <section class="container-site pb-32 reveal">

      <div class="rounded-3xl p-10 md:p-14 bg-gradient-to-r from-[#2c1f35] to-[#3d2b4a] border border-white/10">

        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4 reveal delay-1">
          Próximo paso
        </p>

        <h2 class="text-5xl md:text-6xl mb-6 leading-none reveal delay-2">
          ¿Quieres vivirlo con ARIA?
        </h2>

        <p class="text-white/70 max-w-2xl mb-8 text-lg reveal delay-3">
          Únete a una nueva generación de estudiantes que compiten, aprenden y construyen algo grande.
        </p>

        <div class="flex flex-wrap gap-4 reveal delay-4">

          <a href="/unirse" class="btn-primary">
            Aplicar
          </a>

          <a href="/contacto" class="btn-secondary">
            Contactar
          </a>

        </div>

      </div>

    </section>

  </main>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const items = document.querySelectorAll(".reveal");

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("show");
          }
        });
      }, { threshold: 0.15 });

      items.forEach((item) => observer.observe(item));
    });
  </script>

</BaseLayout>