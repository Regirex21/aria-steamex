---
// src/pages/nosotras.astro

import BaseLayout from "../layouts/baselayout.astro";
import Navbar from "../components/navbar.astro";
---

<BaseLayout title="Nosotras | ARIA STEAMEX">

  <Navbar />

  <main class="overflow-hidden">

    <!-- HERO -->
    <section class="container-site pt-28 pb-24 text-center relative overflow-hidden">

  <div class="glow-orb w-56 h-56 bg-purple-400/20 top-10 right-20"></div>
  <div class="glow-orb w-40 h-40 bg-pink-300/10 bottom-0 left-10"></div>

  <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-6 reveal show">
    Nosotras
  </p>

  <h1 class="text-6xl md:text-8xl max-w-5xl mx-auto leading-none mb-8 reveal show">
    Donde el talento femenino compite en grande
  </h1>

  <p class="text-xl text-white/70 max-w-3xl mx-auto leading-relaxed mb-10 reveal show">
    ARIA STEAMEX desarrolla líderes, ingenieras y agentes de cambio a través de robótica competitiva, excelencia técnica y propósito social.
  </p>

  <div class="flex flex-wrap justify-center gap-8 text-sm text-white/70 reveal show">

    <div>
      <strong class="block text-white text-xl">2025</strong>
      Fundación
    </div>

    <div>
      <strong class="block text-white text-xl">CDMX</strong>
      Base comunitaria
    </div>

    <div>
      <strong class="block text-white text-xl">Femenil</strong>
      Liderazgo STEM
    </div>

  </div>

</section>
    <!-- HISTORIA -->
    <section class="container-site pb-28 reveal">

      <div class="grid lg:grid-cols-2 gap-14 items-start">

        <div>
          <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
            Nuestra historia
          </p>

          <h2 class="text-5xl md:text-6xl leading-none mb-6">
            Nacimos para abrir camino
          </h2>
        </div>

        <div>
          <p class="text-white/72 text-lg leading-relaxed mb-6">
            Fundado en 2025, ARIA STEAMEX surge como una iniciativa comunitaria,
            independiente y gratuita enfocada en expandir el acceso femenino a
            oportunidades reales dentro de ingeniería, tecnología y liderazgo.
          </p>

          <p class="text-white/60 leading-relaxed">
            Nuestro objetivo no es solo competir en FIRST Robotics Competition.
            Buscamos construir una plataforma donde jóvenes puedan crecer técnica
            y personalmente mientras representan a México con excelencia.
          </p>
        </div>

      </div>

    </section>

    <!-- MISION VISION -->
    <section class="container-site pb-28">

      <div class="grid lg:grid-cols-2 gap-6">

        <div class="glass rounded-3xl p-8 reveal">
          <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
            Misión
          </p>

          <h3 class="text-4xl mb-5">
            Formar talento real
          </h3>

          <p class="text-white/70 leading-relaxed">
            Formar y empoderar a jóvenes mujeres mediante la participación en FIRST Robotics Competition, desarrollando sus habilidades técnicas, liderazgo y valores, a través de un entorno colaborativo, disciplinado e innovador que promueva la excelencia y el impacto positivo en la sociedad.
          </p>
        </div>

        <div class="glass rounded-3xl p-8 reveal delay-2">
          <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
            Visión
          </p>

          <h3 class="text-4xl mb-5">
            Ser referencia nacional
          </h3>

          <p class="text-white/70 leading-relaxed">
            Consolidarse como un equipo líder a nivel nacional e internacional en FIRST Robotics Competition, reconocido por su excelencia técnica, su organización estratégica y su contribución al impulso del liderazgo femenino en las áreas STEM, inspirando a nuevas generaciones a seguir el camino de la innovación y el conocimiento.
          </p>
        </div>

      </div>

    </section>

    <!-- VALORES -->
    <section class="container-site pb-28">

      <div class="mb-10 reveal">
        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
          Valores
        </p>

        <h2 class="text-5xl leading-none">
          Lo que nos define
        </h2>
      </div>

      <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6">

        <div class="glass rounded-3xl p-7 reveal">
          <h3 class="text-3xl mb-4">Excelencia</h3>
          <p class="text-white/65">
            Buscar alto rendimiento dentro y fuera del campo.
          </p>
        </div>

        <div class="glass rounded-3xl p-7 reveal delay-1">
          <h3 class="text-3xl mb-4">Comunidad</h3>
          <p class="text-white/65">
            Crecer juntas y abrir oportunidades a otras jóvenes.
          </p>
        </div>

        <div class="glass rounded-3xl p-7 reveal delay-2">
          <h3 class="text-3xl mb-4">Liderazgo</h3>
          <p class="text-white/65">
            Desarrollar voz, criterio y capacidad de impacto.
          </p>
        </div>

        <div class="glass rounded-3xl p-7 reveal delay-3">
          <h3 class="text-3xl mb-4">Disciplina</h3>
          <p class="text-white/65">
            Constancia, profesionalismo y mejora continua.
          </p>
        </div>

      </div>

    </section>

    <!-- COACHES -->
    <section class="container-site pb-28 reveal">

      <div class="grid lg:grid-cols-2 gap-10 items-center">

        <div>
          <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
            Liderazgo
          </p>

          <h2 class="text-5xl md:text-6xl leading-none mb-6">
            Mentoras y coaches
          </h2>

          <p class="text-white/70 text-lg leading-relaxed">
            Nuestro equipo se fortalece mediante acompañamiento técnico,
            estratégico y humano de mentoras, coaches y aliados comprometidos
            con el crecimiento de nuevas generaciones.
          </p>
          <a href="/liderazgo" class="btn-secondary mt-8 inline-flex">
            Conocer liderazgo →
          </a>
        </div>

        <div class="glass rounded-3xl min-h-[320px] p-8 flex items-center justify-center">
          <div class="text-center">
            <p class="text-white/50 mb-3">Placeholder</p>
            <p class="text-3xl">coach profiles / leadership</p>
          </div>
        </div>

      </div>

    </section>

    <!-- CTA -->
    <section class="container-site pb-32 reveal">

      <div class="rounded-3xl p-10 md:p-14 bg-gradient-to-r from-[#2c1f35] to-[#3d2b4a] border border-white/10">

        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4 reveal delay-1">
          Próximo paso
        </p>

        <h2 class="text-5xl md:text-6xl mb-6 leading-none reveal delay-2">
          Sé parte de la próxima generación
        </h2>

        <p class="text-white/70 max-w-2xl mb-8 text-lg reveal delay-3">
          Si buscas crecer, aprender y construir algo grande, ARIA STEAMEX
          puede ser tu siguiente paso.
        </p>

        <div class="flex flex-wrap gap-4 reveal delay-4">

          <a href="/unirse" class="btn-primary">
            Aplicar
          </a>

          <a href="/contacto" class="btn-secondary">
            Contactar
          </a>

        </div>

      </div>

    </section>

  </main>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const items = document.querySelectorAll(".reveal");

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("show");
          }
        });
      }, { threshold: 0.15 });

      items.forEach((item) => observer.observe(item));
    });
  </script>

</BaseLayout>