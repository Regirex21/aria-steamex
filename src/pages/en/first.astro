---
// src/pages/en/first.astro

import BaseLayout from "../../layouts/baselayout.astro";
import Navbar from "../../components/navbar.astro";
---

<BaseLayout title="FIRST / FRC | ARIA STEAMEX" lang="en">

  <Navbar />

  <main class="overflow-hidden">

    <!-- HERO -->
    <section class="container-site pt-28 pb-24 text-center relative overflow-hidden">

      <div class="glow-orb w-56 h-56 bg-purple-400/20 top-10 right-20"></div>
      <div class="glow-orb w-40 h-40 bg-pink-300/10 bottom-0 left-10"></div>

      <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-6 reveal show">
        FIRST Robotics Competition
      </p>

      <h1 class="text-6xl md:text-8xl max-w-5xl mx-auto leading-none mb-8 reveal show">
        More than robots
      </h1>

      <p class="text-xl text-white/70 max-w-3xl mx-auto leading-relaxed mb-10 reveal show">
        FIRST combines engineering, strategy, business, and teamwork in one of the world's most prestigious student experiences.
      </p>

      <div class="flex flex-wrap justify-center gap-8 text-sm text-white/70 reveal show">

        <div>
          <strong class="block text-white text-xl">Global</strong>
          International community
        </div>

        <div>
          <strong class="block text-white text-xl">STEAM</strong>
          Applied education
        </div>

        <div>
          <strong class="block text-white text-xl">Impact</strong>
          Youth leadership
        </div>

        <div>
          <strong class="block text-white text-xl">FRC</strong>
          Elite level
        </div>

      </div>

    </section>

    <!-- WHAT IS FIRST -->
    <section class="container-site pb-28">

      <div class="mb-10 reveal">
        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
          What is FIRST
        </p>

        <h2 class="text-5xl leading-none">
          A platform for growth
        </h2>
      </div>

      <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6">

  <div class="glass rounded-3xl p-6 min-h-[170px] reveal">
    <h3 class="text-2xl mb-4">Mechanical</h3>
    <p class="text-white/65">
      Design, assembly, and physical robot systems.
    </p>
  </div>

  <div class="glass rounded-3xl p-6 min-h-[170px] reveal delay-1">
    <h3 class="text-2xl mb-4">Programming</h3>
    <p class="text-white/65">
      Code, sensors, automation, and robot control.
    </p>
  </div>

  <div class="glass rounded-3xl p-6 min-h-[170px] reveal delay-2">
    <h3 class="text-2xl mb-4">Electronics</h3>
    <p class="text-white/65">
      Wiring, power, integration, and electrical systems.
    </p>
  </div>

  <div class="glass rounded-3xl p-6 min-h-[170px] reveal delay-3">
    <h3 class="text-2xl mb-4">Business</h3>
    <p class="text-white/65">
      Sponsors, budget, and financial strategy.
    </p>
  </div>

  <div class="glass rounded-3xl p-6 min-h-[170px] reveal">
    <h3 class="text-2xl mb-4">Leadership</h3>
    <p class="text-white/65">
      Organization, communication, and team direction.
    </p>
  </div>

  <div class="glass rounded-3xl p-6 min-h-[170px] reveal delay-1">
    <h3 class="text-2xl mb-4">Operations</h3>
    <p class="text-white/65">
      Planning, logistics, and overall coordination.
    </p>
  </div>

  <div class="glass rounded-3xl p-6 min-h-[170px] reveal delay-2">
    <h3 class="text-2xl mb-4">Brand</h3>
    <p class="text-white/65">
      Branding, social media, content, and public presence.
    </p>
  </div>

  <div class="glass rounded-3xl p-6 min-h-[170px] reveal delay-3">
    <h3 class="text-2xl mb-4">Impact</h3>
    <p class="text-white/65">
      Outreach, community, and STEM promotion.
    </p>
  </div>

</div>
    </section>

    <!-- WHAT IS FRC -->

<section class="container-site pb-28 reveal">

  <div class="rounded-3xl border border-white/10 glass p-10 md:p-14 relative overflow-hidden">

    <div class="glow-orb w-44 h-44 bg-purple-400/10 top-0 right-10"></div>

    <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-5">
      What is FRC
    </p>

    <h2 class="text-5xl md:text-7xl leading-none mb-8 max-w-4xl">
      The most intense student robotics experience
    </h2>

    <p class="text-white/72 text-lg max-w-3xl leading-relaxed mb-10">
      FIRST Robotics Competition challenges students to design,
      manufacture, and program high-performance robots to compete
      every year in a new official game alongside thousands of teams worldwide.
    </p>

    <div class="flex flex-wrap gap-4 mb-10">

  <div class="glass rounded-3xl px-6 py-4 w-[220px]">
    <p class="text-4xl leading-none mb-1">6+</p>
    <p class="text-white/60 text-sm">Weeks of build season</p>
  </div>

  <div class="glass rounded-3xl px-6 py-4 w-[220px]">
    <p class="text-4xl leading-none mb-1">1</p>
    <p class="text-white/60 text-sm">New game each year</p>
  </div>

  <div class="glass rounded-3xl px-6 py-4 w-[220px]">
    <p class="text-4xl leading-none mb-1">Global</p>
    <p class="text-white/60 text-sm">International community</p>
  </div>

  <div class="glass rounded-3xl px-6 py-4 w-[220px]">
    <p class="text-4xl leading-none mb-1">Real</p>
    <p class="text-white/60 text-sm">Applied engineering</p>
  </div>

  <div class="flex flex-wrap gap-4 ">

      <a
        href="https://www.firstinspires.org"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary my-4"
      >
        Official FIRST website
      </a>

      <a href="/en/join" class="btn-secondary my-4">
        Experience it with ARIA
      </a>

    </div>

</section>
    <!-- WHAT YOU LEARN -->
    <section class="container-site pb-28">

      <div class="mb-10 reveal">
        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
          What you learn
        </p>

        <h2 class="text-5xl leading-none">
          More than competing
        </h2>
      </div>

      <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-6">

        <div class="glass rounded-3xl p-7 reveal">
          <h3 class="text-3xl mb-4">CAD</h3>
          <p class="text-white/65">Professional mechanical design.</p>
        </div>

        <div class="glass rounded-3xl p-7 reveal delay-1">
          <h3 class="text-3xl mb-4">Manufacturing</h3>
          <p class="text-white/65">Real processes and fabrication.</p>
        </div>

        <div class="glass rounded-3xl p-7 reveal delay-2">
          <h3 class="text-3xl mb-4">Code</h3>
          <p class="text-white/65">Software for physical systems.</p>
        </div>

        <div class="glass rounded-3xl p-7 reveal">
          <h3 class="text-3xl mb-4">Marketing</h3>
          <p class="text-white/65">Brand, social media, and narrative.</p>
        </div>

        <div class="glass rounded-3xl p-7 reveal delay-1">
          <h3 class="text-3xl mb-4">Business</h3>
          <p class="text-white/65">Relationships with partners and sponsors.</p>
        </div>

        <div class="glass rounded-3xl p-7 reveal delay-2">
          <h3 class="text-3xl mb-4">Leadership</h3>
          <p class="text-white/65">Organization and decision-making.</p>
        </div>

      </div>

    </section>

    <!-- CTA -->
    <section class="container-site pb-32 reveal">

      <div class="rounded-3xl p-10 md:p-14 bg-gradient-to-r from-[#2c1f35] to-[#3d2b4a] border border-white/10">

        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4 reveal delay-1">
          Next step
        </p>

        <h2 class="text-5xl md:text-6xl mb-6 leading-none reveal delay-2">
          Want to experience it with ARIA?
        </h2>

        <p class="text-white/70 max-w-2xl mb-8 text-lg reveal delay-3">
          Join a new generation of students who compete, learn, and build something big.
        </p>

        <div class="flex flex-wrap gap-4 reveal delay-4">

          <a href="/en/join" class="btn-primary">
            Apply
          </a>

          <a href="/en/contact" class="btn-secondary">
            Contact
          </a>

        </div>

      </div>

    </section>

  </main>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const items = document.querySelectorAll(".reveal");

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("show");
          }
        });
      }, { threshold: 0.15 });

      items.forEach((item) => observer.observe(item));
    });
  </script>

</BaseLayout>
