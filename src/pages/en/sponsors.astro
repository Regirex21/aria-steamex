---
// src/pages/en/sponsors.astro

import BaseLayout from "../../layouts/baselayout.astro";
import Navbar from "../../components/navbar.astro";
---

<BaseLayout title="Sponsors | ARIA STEAMEX" lang="en">

  <Navbar />

  <main class="overflow-hidden">

    <!-- HERO -->
    <section class="container-site pt-28 pb-24 text-center relative overflow-hidden">

      <div class="glow-orb w-56 h-56 bg-purple-400/20 top-10 right-20"></div>
      <div class="glow-orb w-40 h-40 bg-pink-300/10 bottom-0 left-10"></div>

      <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-6 reveal show">
        Sponsors & Partners
      </p>

      <h1 class="text-6xl md:text-8xl max-w-5xl mx-auto leading-none mb-8 reveal show">
        We empower talent with real allies
      </h1>

      <p class="text-xl text-white/70 max-w-3xl mx-auto leading-relaxed mb-10 reveal show">
        ARIA STEAMEX seeks companies, institutions, and people who want to invest
        in women leadership, STEM education, and community impact in Mexico.
      </p>

      <div class="flex flex-wrap justify-center gap-4 reveal show">
        <a href="/en/contact" class="btn-primary">
          Become a sponsor
        </a>

        <a href="#tiers" class="btn-secondary">
          See opportunities
        </a>
      </div>

    </section>

    <!-- WHY SUPPORT -->
    <section class="container-site pb-28 reveal">

  <div class="rounded-3xl overflow-hidden border border-white/10">

    <div class="bg-gradient-to-r from-[#2c1f35] to-[#3d2b4a] p-10 md:p-14">

      <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-5">
        Why support us
      </p>

      <h2 class="text-5xl md:text-7xl leading-none mb-8 max-w-5xl">
        A partnership with impact,
        visibility, and future.
      </h2>

      <p class="text-white/72 text-lg max-w-3xl leading-relaxed">
        ARIA STEAMEX connects companies with innovation, women leadership,
        and STEM talent development in Mexico.
      </p>

    </div>

    <div class="grid md:grid-cols-2 xl:grid-cols-4 bg-black/20">

      <div class="p-8 border-t border-white/10 xl:border-r">
        <p class="text-4xl mb-3">Branding</p>
        <p class="text-white/60">
          Presence on the robot, uniforms, and content.
        </p>
      </div>

      <div class="p-8 border-t border-white/10 xl:border-r">
        <p class="text-4xl mb-3">Impact</p>
        <p class="text-white/60">
          Outreach and real opportunities for young women.
        </p>
      </div>

      <div class="p-8 border-t border-white/10 xl:border-r">
        <p class="text-4xl mb-3">STEM</p>
        <p class="text-white/60">
          Applied education and competitive engineering.
        </p>
      </div>

      <div class="p-8 border-t border-white/10">
        <p class="text-4xl mb-3">Mexico</p>
        <p class="text-white/60">
          National talent with international projection.
        </p>
      </div>

    </div>

  </div>

</section>

    <!-- CURRENT / FUTURE SPONSORS -->
    <section class="container-site pb-28 reveal">

      <div class="mb-10">
        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
          Allies
        </p>

        <h2 class="text-5xl leading-none">
          Companies that believe in the future
        </h2>
      </div>

      <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6">

        <div class="rounded-3xl min-h-[220px] bg-white p-4 flex items-center justify-center">
          <img
            src="/assets/Gene_Haas_Foundation_Logo.jpg"
            alt="Gene Haas Foundation"
            class="max-w-full max-h-44 object-contain object-center"
            loading="lazy"
          />
        </div>

        <div class="rounded-3xl min-h-[220px] bg-white p-4 flex items-center justify-center">
          <img
            src="/assets/IntuitiveFoundationLogo.jpg"
            alt="Intuitive Foundation"
            class="max-w-full max-h-44 object-contain object-center"
            loading="lazy"
          />
        </div>

        <div class="rounded-3xl min-h-[220px] bg-white p-4 flex items-center justify-center">
          <img
            src="/assets/Boeing-logo.jpg"
            alt="Boeing"
            class="max-w-full max-h-44 object-contain object-center"
            loading="lazy"
          />
        </div>

        <div class="rounded-3xl min-h-[220px] bg-white p-4 flex items-center justify-center">
          <img
            src="/assets/Solveurs_travel%20_logo%20(1).png"
            alt="Solveurs Travel"
            class="max-w-full max-h-44 object-contain object-center"
            loading="lazy"
          />
        </div>

      </div>

    </section>

    <!-- TIERS -->
    <section id="tiers" class="container-site pb-28">

      <div class="mb-10 reveal">
        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
          Opportunities
        </p>

        <h2 class="text-5xl leading-none">
          Ways to collaborate
        </h2>
      </div>

      <div class="grid lg:grid-cols-3 gap-6">

        <div class="glass rounded-3xl p-8 reveal">
          <p class="text-white/45 text-sm mb-3 uppercase tracking-[0.2em]">
            Technical sponsor
          </p>

          <h3 class="text-4xl mb-4">
            Hardware
          </h3>

          <p class="text-white/65">
            Materials, tools, manufacturing, software, or technical mentorship.
          </p>
        </div>

        <div class="glass rounded-3xl p-8 reveal delay-1">
          <p class="text-white/45 text-sm mb-3 uppercase tracking-[0.2em]">
            Financial sponsor
          </p>

          <h3 class="text-4xl mb-4">
            Funding
          </h3>

          <p class="text-white/65">
            Registration, travel, parts, operations, and program growth.
          </p>
        </div>

        <div class="glass rounded-3xl p-8 reveal delay-2">
          <p class="text-white/45 text-sm mb-3 uppercase tracking-[0.2em]">
            Strategic sponsor
          </p>

          <h3 class="text-4xl mb-4">
            Partnership
          </h3>

          <p class="text-white/65">
            Educational collaborations, events, and shared positioning.
          </p>
        </div>

      </div>

    </section>

    <!-- CTA -->
    <section class="container-site pb-32 reveal">

      <div class="rounded-3xl p-10 md:p-14 bg-gradient-to-r from-[#2c1f35] to-[#3d2b4a] border border-white/10">

        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4 reveal delay-1">
          Next step
        </p>

        <h2 class="text-5xl md:text-6xl mb-6 leading-none reveal delay-2">
          Let's build impact together
        </h2>

        <p class="text-white/70 max-w-2xl mb-8 text-lg reveal delay-3">
          If your company values innovation, leadership, and the future, let's talk.
        </p>

        <div class="flex flex-wrap gap-4 reveal delay-4">

          <a href="/en/contact" class="btn-primary">
            Contact
          </a>

          <a href="/en/about_us" class="btn-secondary">
            Learn about ARIA
          </a>

        </div>

      </div>

    </section>

  </main>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const items = document.querySelectorAll(".reveal");

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("show");
          }
        });
      }, { threshold: 0.15 });

      items.forEach((item) => observer.observe(item));
    });
  </script>

</BaseLayout>
