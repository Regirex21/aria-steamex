---
// src/pages/en/join.astro

import BaseLayout from "../../layouts/baselayout.astro";
import Navbar from "../../components/navbar.astro";
---

<BaseLayout title="Join | ARIA STEAMEX" lang="en">

  <Navbar />

  <main class="overflow-hidden">

    <!-- HERO -->
    <section class="container-site pt-28 pb-24 text-center relative overflow-hidden">

      <div class="glow-orb w-56 h-56 bg-purple-400/20 top-10 right-20"></div>
      <div class="glow-orb w-40 h-40 bg-pink-300/10 bottom-0 left-10"></div>

      <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-6 reveal show">
        Join
      </p>

      <h1 class="text-6xl md:text-8xl max-w-5xl mx-auto leading-none mb-8 reveal show">
        Choose your path
      </h1>

      <p class="text-xl text-white/70 max-w-3xl mx-auto leading-relaxed reveal show">
        ARIA STEAMEX is looking for students eager to grow and mentors ready to empower a new generation.
      </p>

    </section>

    <!-- TWO PATHS -->
    <section class="container-site pb-28">

      <div class="grid lg:grid-cols-2 gap-8">

        <div class="glass rounded-3xl p-10 reveal">

          <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
            Student
          </p>

          <h2 class="text-5xl mb-6 leading-none">
            Join the team
          </h2>

          <p class="text-white/70 text-lg leading-relaxed mb-8">
            If you are a student and want to learn robotics, leadership,
            technology, and compete in FIRST, this space is for you.
          </p>

          <div class="space-y-4 mb-10">

            <div class="flex gap-3">
              <div class="w-2 h-2 rounded-full bg-[var(--primary)] mt-3"></div>
              <p class="text-white/65">No previous experience needed.</p>
            </div>

            <div class="flex gap-3">
              <div class="w-2 h-2 rounded-full bg-[var(--primary)] mt-3"></div>
              <p class="text-white/65">Technical and personal training.</p>
            </div>

            <div class="flex gap-3">
              <div class="w-2 h-2 rounded-full bg-[var(--primary)] mt-3"></div>
              <p class="text-white/65">A competitive and community-driven environment.</p>
            </div>

          </div>

          <div class="flex flex-wrap gap-4">

            <a
              href="https://forms.gle/hYeZ7WfwytA96drKA"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary"
            >
              Apply as a student
            </a>

            <a
              href="https://wa.me/525564876703"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-secondary"
            >
              Direct questions
            </a>

          </div>

        </div>

        <div class="glass rounded-3xl p-10 reveal delay-2">

          <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
            Mentor
          </p>

          <h2 class="text-5xl mb-6 leading-none">
            Empower real talent
          </h2>

          <p class="text-white/70 text-lg leading-relaxed mb-8">
            We are looking for people with professional, technical, or human
            experience who want to support young people in STEM.
          </p>

          <div class="space-y-4 mb-10">

            <div class="flex gap-3">
              <div class="w-2 h-2 rounded-full bg-[var(--primary)] mt-3"></div>
              <p class="text-white/65">Engineering, business, or leadership.</p>
            </div>

            <div class="flex gap-3">
              <div class="w-2 h-2 rounded-full bg-[var(--primary)] mt-3"></div>
              <p class="text-white/65">Direct impact on new generations.</p>
            </div>

            <div class="flex gap-3">
              <div class="w-2 h-2 rounded-full bg-[var(--primary)] mt-3"></div>
              <p class="text-white/65">Flexible and meaningful participation.</p>
            </div>

          </div>

          <div class="flex flex-wrap gap-4">

            <a
              href="https://forms.gle/vGeAdjTnCT9TdxNa9"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary"
            >
              Apply as a mentor
            </a>

            <a
              href="mailto:contacto@ariasteamex.org"
              class="btn-secondary"
            >
              Contact
            </a>

          </div>

        </div>

      </div>

    </section>

    <!-- WHAT YOU CAN JOIN -->
    <section class="container-site pb-28 reveal">

      <div class="rounded-3xl overflow-hidden border border-white/10">

        <div class="bg-gradient-to-r from-[#2c1f35] to-[#3d2b4a] p-10 md:p-14">

          <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-5">
            Team areas
          </p>

          <h2 class="text-5xl md:text-6xl leading-none mb-8 max-w-5xl">
            There is room for different talents
          </h2>

          <p class="text-white/72 text-lg max-w-3xl leading-relaxed">
            It is not all about building robots. A great team needs many strengths.
          </p>

        </div>

        <div class="grid md:grid-cols-2 xl:grid-cols-4 bg-black/20">

          <div class="p-8 border-t border-white/10 xl:border-r">
            <p class="text-3xl mb-3">Technical</p>
            <p class="text-white/60">
              Mechanics, code, and electronics.
            </p>
          </div>

          <div class="p-8 border-t border-white/10 xl:border-r">
            <p class="text-3xl mb-3">Creative</p>
            <p class="text-white/60">
              Branding, media, and content.
            </p>
          </div>

          <div class="p-8 border-t border-white/10 xl:border-r">
            <p class="text-3xl mb-3">Business</p>
            <p class="text-white/60">
              Sponsors, organization, and strategy.
            </p>
          </div>

          <div class="p-8 border-t border-white/10">
            <p class="text-3xl mb-3">Human</p>
            <p class="text-white/60">
              Leadership, mentorship, and impact.
            </p>
          </div>

        </div>

      </div>

    </section>

    <!-- DIRECT CONTACT -->
    <section class="container-site pb-32 reveal">

      <div class="rounded-3xl p-10 md:p-14 bg-gradient-to-r from-[#2c1f35] to-[#3d2b4a] border border-white/10">

        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4 reveal delay-1">
          Direct contact
        </p>

        <h2 class="text-5xl md:text-6xl mb-6 leading-none reveal delay-2">
          Have questions?
        </h2>

        <p class="text-white/70 max-w-2xl mb-8 text-lg reveal delay-3">
          Write to us and we will guide you personally.
        </p>

        <div class="flex flex-wrap gap-4 reveal delay-4">

          <a
            href="https://wa.me/525564876703"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            WhatsApp
          </a>

          <a
            href="mailto:ariasteamex@gmail.com"
            class="btn-secondary"
          >
            Email
          </a>

          <a
            href="https://instagram.com/aria.steamex"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary"
          >
            Instagram
          </a>

        </div>

      </div>

    </section>

  </main>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const items = document.querySelectorAll(".reveal");

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("show");
          }
        });
      }, { threshold: 0.15 });

      items.forEach((item) => observer.observe(item));
    });
  </script>

</BaseLayout>
