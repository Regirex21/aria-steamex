---
import BaseLayout from "../../layouts/baselayout.astro";
import Navbar from "../../components/navbar.astro";
---

<BaseLayout title="ARIA STEAMEX | Official" lang="en">

  <Navbar />

  <main class="overflow-hidden">

    <!-- HERO -->
    <section class="container-site pt-24 pb-28 grid lg:grid-cols-2 gap-14 items-center relative overflow-hidden">

      <div class="glow-orb w-56 h-56 bg-purple-400/20 top-10 right-20"></div>
      <div class="glow-orb w-40 h-40 bg-pink-300/10 bottom-10 left-10"></div>

      <div class="relative z-10 animate-left">

        <p class="text-sm uppercase tracking-[0.25em] text-white/60 mb-4">
          Project STEAMex • Mexico City
        </p>

        <h1 class="text-6xl md:text-8xl leading-none mb-6">
          ARIA
        </h1>

        <p class="text-xl text-white/75 max-w-xl mb-8 leading-relaxed">
          A women-led FIRST Robotics Competition team that builds leaders,
          develops professionals, and opens STEAM opportunities for future engineers.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="/en/join" class="btn-primary">Join</a>
          <a href="/en/contact" class="btn-secondary">Contact Us</a>
        </div>

        <div class="mt-10 flex gap-8 text-sm text-white/70 flex-wrap">
          <div>
            <strong class="text-white block text-lg">FRC</strong>
            Global competition
          </div>

          <div>
            <strong class="text-white block text-lg">100%</strong>
            Free access
          </div>

          <div>
            <strong class="text-white block text-lg">Women</strong>
            Leading in STEAM
          </div>
        </div>

      </div>

      <div class="relative z-10 glass rounded-3xl overflow-hidden min-h-[500px] animate-right delay-2 border border-white/10">
        <img
          src="/assets/IMG_7434.JPG"
          alt="ARIA STEAMEX team"
          class="absolute inset-0 w-full h-full object-cover object-center"
        />

        <div class="absolute inset-0 bg-gradient-to-t from-black/35 via-transparent to-black/10"></div>
      </div>

    </section>

    <!-- QUICK ACCESS GRID -->
    <section class="container-site pb-28 -mt-6">

      <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6">

        <a
          href="/en/about_us"
          class="group glass rounded-3xl p-7 min-h-[240px] transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-purple-500/10 border border-white/5 hover:border-white/15 reveal"
        >
          <div class="flex justify-between items-start mb-10">
            <span class="text-xs tracking-[0.25em] text-white/45 uppercase">
              01
            </span>

            <span class="text-white/30 group-hover:text-white/70 transition">
              →
            </span>
          </div>

          <h2 class="text-4xl mb-4">About Us</h2>

          <p class="text-white/65 leading-relaxed">
            Learn about our mission, vision, story, and leadership within
            Project Steamex.
          </p>
        </a>

        <a
          href="/en/first"
          class="group glass rounded-3xl p-7 min-h-[240px] transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-purple-500/10 border border-white/5 hover:border-white/15 reveal"
        >
          <div class="flex justify-between items-start mb-10">
            <span class="text-xs tracking-[0.25em] text-white/45 uppercase">
              02
            </span>

            <span class="text-white/30 group-hover:text-white/70 transition">
              →
            </span>
          </div>

          <h2 class="text-4xl mb-4">FIRST / FRC</h2>

          <p class="text-white/65 leading-relaxed">
            Discover the world's most prestigious youth robotics competition.
          </p>
        </a>

        <a
          href="/en/impact"
          class="group glass rounded-3xl p-7 min-h-[240px] transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-purple-500/10 border border-white/5 hover:border-white/15 reveal"
        >
          <div class="flex justify-between items-start mb-10">
            <span class="text-xs tracking-[0.25em] text-white/70 uppercase">
              03
            </span>

            <span class="text-white/70 group-hover:text-white transition">
              →
            </span>
          </div>

          <h2 class="text-4xl mb-4">Impact</h2>

          <p class="text-white/70 leading-relaxed">
            Our impact in the community and the development of women talent in STEM.
          </p>
        </a>

        <a
          href="/en/join"
          class="group glass rounded-3xl p-7 min-h-[240px] transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-purple-500/10 border border-white/5 hover:border-white/15 reveal"
        >
          <div class="flex justify-between items-start mb-10">

            <span class="text-xs tracking-[0.25em] text-white/45 uppercase">
              04
            </span>

            <span class="text-white/30 group-hover:text-white/70 transition">
              →
            </span>
          </div>

          <h2 class="text-4xl mb-4">Join</h2>

          <p class="text-white/65 leading-relaxed">
            Recruitment through an application form, intro session, or invitation.
          </p>
        </a>

      </div>
    </section>

    <!-- IMPACT SECTION -->
    <section class="container-site pb-28 reveal">

      <div class="grid lg:grid-cols-2 gap-10 items-center">

        <div>
          <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
            Growth
          </p>

          <h2 class="text-6xl leading-none mb-6">
            Engineering with purpose
          </h2>

          <p class="text-white/70 text-lg max-w-xl leading-relaxed">
            ARIA STEAMEX does more than compete. It builds leaders, develops
            technical talent, and opens real opportunities for women in STEM.
          </p>
        </div>

        <div class="grid grid-cols-2 gap-5">

          <div class="glass rounded-3xl p-6">
            <p class="text-5xl mb-2">FRC</p>
            <p class="text-white/60">International competition</p>
          </div>

          <div class="glass rounded-3xl p-6">
            <p class="text-5xl mb-2">100%</p>
            <p class="text-white/60">Free access</p>
          </div>

          <div class="glass rounded-3xl p-6">
            <p class="text-5xl mb-2">CDMX</p>
            <p class="text-white/60">Community base</p>
          </div>

          <div class="glass rounded-3xl p-6">
            <p class="text-5xl mb-2">2025</p>
            <p class="text-white/60">Founding year</p>
          </div>

        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="container-site pb-32 reveal">

      <div class="rounded-3xl p-10 md:p-14 bg-gradient-to-r from-[#2c1f35] to-[#3d2b4a] border border-white/10">

        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4 reveal delay-1">
          Next step
        </p>

        <h2 class="text-5xl md:text-6xl mb-6 leading-none reveal delay-2">
          Let's build something big
        </h2>

        <p class="text-white/70 max-w-2xl mb-8 text-lg reveal delay-3">
          If you want to join, collaborate, support, or learn more about ARIA STEAMEX,
          now is the moment.
        </p>

        <div class="flex flex-wrap gap-4 reveal delay-4">

          <a href="/en/contact" class="btn-primary">
            Contact
          </a>

          <a href="/en/join" class="btn-secondary">
            Join
          </a>

        </div>

      </div>

    </section>

  </main>
  <script is:inline>
document.addEventListener("DOMContentLoaded", () => {
  const items = document.querySelectorAll(".reveal");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("show");
        }
      });
    },
    {
      threshold: 0.15,
      rootMargin: "0px 0px -50px 0px"
    }
  );

  items.forEach((item) => observer.observe(item));
});
</script>

</BaseLayout>
