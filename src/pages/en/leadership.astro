---
// src/pages/en/leadership.astro

import BaseLayout from "../../layouts/baselayout.astro";
import Navbar from "../../components/navbar.astro";

 const coaches = [
  {
    role: "National Director · Project STEAMEX",
    name: "Abraham Martínez",
    description:
      "Leads the institutional vision of Project STEAMEX and supports the strategic growth of high-impact STEM initiatives.",
    image: "/assets/Mentoras/abraham.png",
  },

  {
    role: "Head Coach",
    name: "Regina Servín",
    description:
      "Leads the team's technical areas, including mechanics, programming, and documentation. Oversees development processes, competitive strategy, and internal technical training.",
    image: "/assets/Mentoras/rex.png",
  },

  {
    role: "Coach",
    name: "Isis Reyes ",
    description:
      "Responsible for sponsorship, impact, and team image. Coordinates partnerships, outreach, branding, and institutional communication strategies.",
    image: "/assets/Mentoras/mei.jpeg",
  },
];

const mentors = [
  {
    name: "Gemma Navarrete",
    area: "Impact",
    description: "Outreach and community.",
    image: "/assets/Mentoras/gemma.jpeg",
  },

  {
    name: "Paulina Peña",
    area: "Impact",
    description: "Outreach and community.",
    image: "/assets/Mentoras/pau.png",
  },

  {
    name: "Britany Valadez",
    area: "Mechanics and Programming",
    description: "Training and development of technical content.",
    image: "/assets/Mentoras/bri.jpeg",
  },

  {
    name: "Renata Servín",
    area: "Mechanics",
    description: "Design, assembly, and manufacturing.",
    image: "/assets/Mentoras/renata.jpeg",
  },

  {
    name: "Katheryn Azano",
    area: "Programming",
    description: "Software development and automation.",
    image: "/assets/Mentoras/katy.png",
  },
];
---



<BaseLayout title="Leadership | ARIA STEAMEX" lang="en">

  <Navbar />

  <main class="overflow-hidden">

    <!-- HERO -->
    <section class="container-site pt-28 pb-24 text-center relative overflow-hidden">

      <div class="glow-orb w-56 h-56 bg-purple-400/20 top-10 right-20"></div>
      <div class="glow-orb w-40 h-40 bg-pink-300/10 bottom-0 left-10"></div>

      <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-6 reveal show">
        Meet the leadership
      </p>

      <h1 class="text-6xl md:text-8xl max-w-5xl mx-auto leading-none mb-8 reveal show">
        People who build opportunities
      </h1>

      <p class="text-xl text-white/70 max-w-3xl mx-auto leading-relaxed reveal show">
        ARIA STEAMEX grows thanks to coaches, mentors, and allies committed
        to training a new generation of women leaders in STEM.
      </p>

    </section>

    <!-- LEADERSHIP INTRO -->
    <section class="container-site pb-24 reveal">

      <div class="rounded-3xl p-10 md:p-14 bg-gradient-to-r from-[#2c1f35] to-[#3d2b4a] border border-white/10">

        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-5">
          Our philosophy
        </p>

        <h2 class="text-5xl md:text-6xl leading-none mb-8 max-w-5xl">
          To lead is to serve, teach, and raise standards.
        </h2>

        <p class="text-white/72 text-lg max-w-3xl leading-relaxed">
          We are not looking for decorative figures. We look for active leadership:
          people who teach, guide, demand excellence, and open the way.
        </p>

      </div>

    </section>

<!-- COACHES -->
<section class="container-site pb-28">

  <div class="mb-10 reveal">
    <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
      Coaches
    </p>

<h2 class="text-5xl leading-none">
  Direction & institutional leadership
</h2>
  </div>

  <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-6">

    {
      coaches.map((coach, index) => (
        <div class={`glass rounded-3xl p-8 reveal delay-${index}`}>
          
          <div class="w-full h-[320px] rounded-2xl border border-white/10 mb-6 overflow-hidden">
            <img
              src={coach.image}
              alt={coach.name}
              class="w-full h-full max-h-full max-w-full object-cover"
            />
          </div>

          <p class="text-sm uppercase tracking-[0.2em] text-white/45 mb-3">
            {coach.role}
          </p>

          <h3 class="text-4xl mb-4">
            {coach.name}
          </h3>

          <p class="text-white/65 leading-relaxed">
            {coach.description}
          </p>

        </div>
      ))
    }

  </div>

</section>

<!-- LEADERSHIP TEAM -->
<section class="container-site pb-28">

  <div class="mb-10 reveal">
    <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
      Mentors
    </p>

    <h2 class="text-5xl leading-none">
      People who drive key areas
    </h2>
  </div>

  <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-6">

  {
    mentors.map((mentor, index) => (
      <div class="glass rounded-3xl p-6 reveal">

        <div class="w-full h-[260px] rounded-2xl border border-white/10 mb-6 overflow-hidden">
          <img
            src={mentor.image}
            alt={mentor.name}
            class="w-full h-full max-h-full max-w-full object-cover"
          />
        </div>

        <div class="text-center">

          <p class="text-xs uppercase tracking-[0.22em] text-white/45 mb-3">
            {mentor.area}
          </p>

          <h3 class="text-2xl mb-3 leading-none">
            {mentor.name}
          </h3>

          <p class="text-white/65 text-sm leading-relaxed">
            {mentor.description}
          </p>

        </div>

      </div>
    ))
  }

</div>

</section>


    <!-- CTA -->
    <section class="container-site pb-32 reveal">

      <div class="rounded-3xl p-10 md:p-14 bg-gradient-to-r from-[#2c1f35] to-[#3d2b4a] border border-white/10">

        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4 reveal delay-1">
          Next step
        </p>

        <h2 class="text-5xl md:text-6xl mb-6 leading-none reveal delay-2">
          Want to support this mission?
        </h2>

        <p class="text-white/70 max-w-2xl mb-8 text-lg reveal delay-3">
          We are looking for new mentors, allies, and people ready to build the future.
        </p>

        <div class="flex flex-wrap gap-4 reveal delay-4">

          <a href="/en/join" class="btn-primary">
            Apply as a mentor
          </a>

          <a href="/en/contact" class="btn-secondary">
            Contact
          </a>

        </div>

      </div>

    </section>

  </main>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const items = document.querySelectorAll(".reveal");

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("show");
          }
        });
      }, { threshold: 0.15 });

      items.forEach((item) => observer.observe(item));
    });
  </script>

 

</BaseLayout>
