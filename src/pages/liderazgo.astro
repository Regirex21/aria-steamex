---
// src/pages/liderazgo.astro

import BaseLayout from "../layouts/baselayout.astro";
import Navbar from "../components/navbar.astro";
---

<BaseLayout title="Liderazgo | ARIA STEAMEX">

  <Navbar />

  <main class="overflow-hidden">

    <!-- HERO -->
    <section class="container-site pt-28 pb-24 text-center relative overflow-hidden">

      <div class="glow-orb w-56 h-56 bg-purple-400/20 top-10 right-20"></div>
      <div class="glow-orb w-40 h-40 bg-pink-300/10 bottom-0 left-10"></div>

      <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-6 reveal show">
        Conoce al liderazgo
      </p>

      <h1 class="text-6xl md:text-8xl max-w-5xl mx-auto leading-none mb-8 reveal show">
        Personas que construyen oportunidades
      </h1>

      <p class="text-xl text-white/70 max-w-3xl mx-auto leading-relaxed reveal show">
        ARIA STEAMEX crece gracias a coaches, mentoras y aliados comprometidos
        con formar una nueva generación de mujeres líderes en STEM.
      </p>

    </section>

    <!-- LEADERSHIP INTRO -->
    <section class="container-site pb-24 reveal">

      <div class="rounded-3xl p-10 md:p-14 bg-gradient-to-r from-[#2c1f35] to-[#3d2b4a] border border-white/10">

        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-5">
          Nuestra filosofía
        </p>

        <h2 class="text-5xl md:text-6xl leading-none mb-8 max-w-5xl">
          Liderar es servir, enseñar y elevar estándares.
        </h2>

        <p class="text-white/72 text-lg max-w-3xl leading-relaxed">
          No buscamos figuras decorativas. Buscamos liderazgo activo:
          personas que enseñan, acompañan, exigen excelencia y abren camino.
        </p>

      </div>

    </section>

    <!-- COACHES -->
    <section class="container-site pb-28">

      <div class="mb-10 reveal">
        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
          Coaches
        </p>

        <h2 class="text-5xl leading-none">
          Dirección principal
        </h2>
      </div>

      <div class="grid lg:grid-cols-2 gap-8">

        <!-- HEAD COACH -->
        <div class="glass rounded-3xl p-8 reveal">

          <div class="aspect-[4/3] rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mb-6">
            <div class="text-center">
              <p class="text-white/45 text-sm mb-2">Placeholder</p>
              <p class="text-2xl">Foto Head Coach</p>
            </div>
          </div>

          <p class="text-sm uppercase tracking-[0.2em] text-white/45 mb-3">
            Head Coach
          </p>

          <h3 class="text-4xl mb-4">
            Nombre Coach Principal
          </h3>

          <p class="text-white/65 leading-relaxed">
            Lidera estrategia general, crecimiento institucional, cultura del equipo
            y visión a largo plazo.
          </p>

        </div>

        <!-- ASSISTANT -->
        <div class="glass rounded-3xl p-8 reveal delay-1">

          <div class="aspect-[4/3] rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mb-6">
            <div class="text-center">
              <p class="text-white/45 text-sm mb-2">Placeholder</p>
              <p class="text-2xl">Foto Coach</p>
            </div>
          </div>

          <p class="text-sm uppercase tracking-[0.2em] text-white/45 mb-3">
            Coach
          </p>

          <h3 class="text-4xl mb-4">
            Nombre Coach
          </h3>

          <p class="text-white/65 leading-relaxed">
            Apoya operaciones, mentoría diaria y ejecución de programas internos.
          </p>

        </div>

      </div>

    </section>

    <!-- LEADERSHIP TEAM -->
<section class="container-site pb-28">

  <div class="mb-10 reveal">
    <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
      Mentoras & Mentores
    </p>

    <h2 class="text-5xl leading-none">
      Personas que impulsan áreas clave
    </h2>
  </div>

  <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-6">

    <!-- MECANICA -->
    <div class="glass rounded-3xl overflow-hidden reveal">
      <div class="aspect-[4/3] bg-white/5 border-b border-white/10 flex items-center justify-center">
        <p class="text-white/45">Foto Mentor</p>
      </div>
      <div class="p-6">
        <p class="text-sm uppercase text-white/45 mb-2">Mentor</p>
        <h3 class="text-2xl mb-2">Mecánica</h3>
        <p class="text-white/65 text-sm">Diseño, ensamble y manufactura.</p>
      </div>
    </div>

    <!-- PROGRAMACION -->
    <div class="glass rounded-3xl overflow-hidden reveal delay-1">
      <div class="aspect-[4/3] bg-white/5 border-b border-white/10 flex items-center justify-center">
        <p class="text-white/45">Foto Mentor</p>
      </div>
      <div class="p-6">
        <p class="text-sm uppercase text-white/45 mb-2">Mentor</p>
        <h3 class="text-2xl mb-2">Programación</h3>
        <p class="text-white/65 text-sm">Software, control y automatización.</p>
      </div>
    </div>

    <!-- IMPACTO -->
    <div class="glass rounded-3xl overflow-hidden reveal delay-2">
      <div class="aspect-[4/3] bg-white/5 border-b border-white/10 flex items-center justify-center">
        <p class="text-white/45">Foto Mentor</p>
      </div>
      <div class="p-6">
        <p class="text-sm uppercase text-white/45 mb-2">Mentor</p>
        <h3 class="text-2xl mb-2">Impacto</h3>
        <p class="text-white/65 text-sm">Outreach y comunidad.</p>
      </div>
    </div>

    <!-- REDES -->
    <div class="glass rounded-3xl overflow-hidden reveal">
      <div class="aspect-[4/3] bg-white/5 border-b border-white/10 flex items-center justify-center">
        <p class="text-white/45">Foto Mentor</p>
      </div>
      <div class="p-6">
        <p class="text-sm uppercase text-white/45 mb-2">Mentor</p>
        <h3 class="text-2xl mb-2">Redes</h3>
        <p class="text-white/65 text-sm">Contenido y branding.</p>
      </div>
    </div>

    <!-- PATROCINIOS -->
    <div class="glass rounded-3xl overflow-hidden reveal delay-1">
      <div class="aspect-[4/3] bg-white/5 border-b border-white/10 flex items-center justify-center">
        <p class="text-white/45">Foto Mentor</p>
      </div>
      <div class="p-6">
        <p class="text-sm uppercase text-white/45 mb-2">Mentor</p>
        <h3 class="text-2xl mb-2">Patrocinios</h3>
        <p class="text-white/65 text-sm">Sponsors y alianzas estratégicas.</p>
      </div>
    </div>

  </div>

</section>


    <!-- CTA -->
    <section class="container-site pb-32 reveal">

      <div class="rounded-3xl p-10 md:p-14 bg-gradient-to-r from-[#2c1f35] to-[#3d2b4a] border border-white/10">

        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4 reveal delay-1">
          Próximo paso
        </p>

        <h2 class="text-5xl md:text-6xl mb-6 leading-none reveal delay-2">
          ¿Quieres apoyar esta misión?
        </h2>

        <p class="text-white/70 max-w-2xl mb-8 text-lg reveal delay-3">
          Buscamos nuevas mentoras, aliados y personas listas para construir futuro.
        </p>

        <div class="flex flex-wrap gap-4 reveal delay-4">

          <a href="/unirse" class="btn-primary">
            Aplicar como mentor(a)
          </a>

          <a href="/contacto" class="btn-secondary">
            Contactar
          </a>

        </div>

      </div>

    </section>

  </main>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const items = document.querySelectorAll(".reveal");

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("show");
          }
        });
      }, { threshold: 0.15 });

      items.forEach((item) => observer.observe(item));
    });
  </script>

</BaseLayout>