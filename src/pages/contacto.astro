---
// src/pages/contacto.astro

import BaseLayout from "../layouts/baselayout.astro";
import Navbar from "../components/navbar.astro";
---

<BaseLayout title="Contacto | ARIA STEAMEX">

  <Navbar />

  <main class="overflow-hidden">

    <!-- HERO -->
    <section class="container-site pt-28 pb-24 text-center relative overflow-hidden">

      <div class="glow-orb w-56 h-56 bg-purple-400/20 top-10 right-20"></div>
      <div class="glow-orb w-40 h-40 bg-pink-300/10 bottom-0 left-10"></div>

      <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-6 reveal show">
        Contacto
      </p>

      <h1 class="text-6xl md:text-8xl max-w-5xl mx-auto leading-none mb-8 reveal show">
        Hablemos
      </h1>

      <p class="text-xl text-white/70 max-w-3xl mx-auto leading-relaxed reveal show">
        Si quieres unirte, colaborar, patrocinar o conocer más sobre ARIA STEAMEX,
        este es el mejor lugar para comenzar.
      </p>

    </section>

    <!-- CONTACT OPTIONS -->
    <section class="container-site pb-28">

      <div class="grid lg:grid-cols-3 gap-6">

        <!-- Email -->
        <div class="glass rounded-3xl p-8 reveal">

  <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
    Correo
  </p>

  <h2 class="text-4xl mb-5">
    Email oficial
  </h2>

  <p class="text-white/65 mb-6 leading-relaxed">
    Para alianzas, dudas generales, prensa o propuestas formales.
  </p>

  <div class="flex flex-wrap gap-3">

    <a
      href="mailto:ariasteamex@gmail.com"
      class="btn-primary"
    >
      Enviar correo
    </a>

    <button
      class="btn-secondary copy-email"
      data-email="ariasteamex@gmail.com"
    >
      Copiar correo
    </button>

  </div>

</div>

        <!-- WhatsApp -->
        <div class="glass rounded-3xl p-8 reveal delay-1">

          <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
            WhatsApp
          </p>

          <h2 class="text-4xl mb-5">
            Coach principal
          </h2>

          <p class="text-white/65 mb-6 leading-relaxed">
            Canal rápido para información, sponsors o dudas directas.
          </p>

          <a
  href="https://wa.me/525564876703"
  target="_blank"
  rel="noopener noreferrer"
  class="btn-primary inline-flex"
>
  Abrir WhatsApp
</a>

        </div>

        <!-- Instagram -->
        <div class="glass rounded-3xl p-8 reveal delay-2">

          <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
            Redes
          </p>

          <h2 class="text-4xl mb-5">
            Instagram
          </h2>

          <p class="text-white/65 mb-6 leading-relaxed">
            Sigue avances, convocatorias y vida del equipo.
          </p>

          <a
            href="https://instagram.com/aria.steamex"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary inline-flex"
          >
            @aria.steamex
          </a>

        </div>

      </div>

    </section>

    <!-- WHAT TO CONTACT FOR -->
    <section class="container-site pb-28 reveal">

      <div class="rounded-3xl overflow-hidden border border-white/10">

        <div class="bg-gradient-to-r from-[#2c1f35] to-[#3d2b4a] p-10 md:p-14">

          <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-5">
            Podemos ayudarte con
          </p>

          <h2 class="text-5xl md:text-6xl leading-none mb-8 max-w-5xl">
            Más que preguntas.
            <br />
            Oportunidades reales.
          </h2>

          <p class="text-white/72 text-lg max-w-3xl leading-relaxed">
            Estamos abiertas a nuevas integrantes, sponsors, medios,
            instituciones educativas y alianzas estratégicas.
          </p>

        </div>

        <div class="grid md:grid-cols-2 xl:grid-cols-4 bg-black/20">

          <div class="p-8 border-t border-white/10 xl:border-r">
            <p class="text-3xl mb-3">Unirse</p>
            <p class="text-white/60">
              Proceso de ingreso y convocatorias.
            </p>
          </div>

          <div class="p-8 border-t border-white/10 xl:border-r">
            <p class="text-3xl mb-3">Sponsors</p>
            <p class="text-white/60">
              Patrocinios y colaboración empresarial.
            </p>
          </div>

          <div class="p-8 border-t border-white/10 xl:border-r">
            <p class="text-3xl mb-3">Escuelas</p>
            <p class="text-white/60">
              Activaciones y proyectos educativos.
            </p>
          </div>

          <div class="p-8 border-t border-white/10">
            <p class="text-3xl mb-3">Medios</p>
            <p class="text-white/60">
              Entrevistas, prensa y difusión.
            </p>
          </div>

        </div>

      </div>

    </section>

    <!-- FINAL CTA -->
    <section class="container-site pb-32 reveal">

      <div class="rounded-3xl p-10 md:p-14 bg-gradient-to-r from-[#2c1f35] to-[#3d2b4a] border border-white/10">

        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4 reveal delay-1">
          Próximo paso
        </p>

        <h2 class="text-5xl md:text-6xl mb-6 leading-none reveal delay-2">
          Empecemos una conversación
        </h2>

        <p class="text-white/70 max-w-2xl mb-8 text-lg reveal delay-3">
          Grandes oportunidades comienzan con un mensaje.
        </p>

        <div class="flex flex-wrap gap-4 reveal delay-4">

  <a href="mailto:ariasteamex@gmail.com" class="btn-primary">
    Enviar correo
  </a>

  <button
    class="btn-secondary copy-email"
    data-email="ariasteamex@gmail.com"
  >
    Copiar correo
  </button>

  <a href="/sponsors" class="btn-secondary">
    Ver sponsors
  </a>

</div>

      </div>

    </section>

  </main>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const items = document.querySelectorAll(".reveal");

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("show");
          }
        });
      }, { threshold: 0.15 });

      items.forEach((item) => observer.observe(item));
    });
  </script>

</BaseLayout>