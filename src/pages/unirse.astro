---
// src/pages/unirse.astro

import BaseLayout from "../layouts/baselayout.astro";
import Navbar from "../components/navbar.astro";
---

<BaseLayout title="Unirse | ARIA STEAMEX">

  <Navbar />

  <main class="overflow-hidden">

    <!-- HERO -->
    <section class="container-site pt-28 pb-24 text-center relative overflow-hidden">

      <div class="glow-orb w-56 h-56 bg-purple-400/20 top-10 right-20"></div>
      <div class="glow-orb w-40 h-40 bg-pink-300/10 bottom-0 left-10"></div>

      <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-6 reveal show">
        Unirse
      </p>

      <h1 class="text-6xl md:text-8xl max-w-5xl mx-auto leading-none mb-8 reveal show">
        Elige tu camino
      </h1>

      <p class="text-xl text-white/70 max-w-3xl mx-auto leading-relaxed reveal show">
        ARIA STEAMEX busca alumnas con ganas de crecer y mentoras dispuestas a impulsar una nueva generación.
      </p>

    </section>

    <!-- TWO PATHS -->
    <section class="container-site pb-28">

      <div class="grid lg:grid-cols-2 gap-8">

        <!-- STUDENT -->
        <div class="glass rounded-3xl p-10 reveal">

          <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
            Alumna
          </p>

          <h2 class="text-5xl mb-6 leading-none">
            Únete al equipo
          </h2>

          <p class="text-white/70 text-lg leading-relaxed mb-8">
            Si eres estudiante y quieres aprender robótica, liderazgo,
            tecnología y competir en FIRST, este espacio es para ti.
          </p>

          <div class="space-y-4 mb-10">

            <div class="flex gap-3">
              <div class="w-2 h-2 rounded-full bg-[var(--primary)] mt-3"></div>
              <p class="text-white/65">No necesitas experiencia previa.</p>
            </div>

            <div class="flex gap-3">
              <div class="w-2 h-2 rounded-full bg-[var(--primary)] mt-3"></div>
              <p class="text-white/65">Capacitación técnica y personal.</p>
            </div>

            <div class="flex gap-3">
              <div class="w-2 h-2 rounded-full bg-[var(--primary)] mt-3"></div>
              <p class="text-white/65">Ambiente competitivo y comunitario.</p>
            </div>

          </div>

          <div class="flex flex-wrap gap-4">

            <a
              href="https://forms.gle/TUFORMALUMNAS"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary"
            >
              Aplicar como alumna
            </a>

            <a
              href="https://wa.me/525564876703"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-secondary"
            >
              Dudas directas
            </a>

          </div>

        </div>

        <!-- MENTOR -->
        <div class="glass rounded-3xl p-10 reveal delay-2">

          <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
            Mentora / Mentor
          </p>

          <h2 class="text-5xl mb-6 leading-none">
            Impulsa talento real
          </h2>

          <p class="text-white/70 text-lg leading-relaxed mb-8">
            Buscamos personas con experiencia profesional, técnica o humana
            que quieran apoyar el crecimiento de jóvenes en STEM.
          </p>

          <div class="space-y-4 mb-10">

            <div class="flex gap-3">
              <div class="w-2 h-2 rounded-full bg-[var(--primary)] mt-3"></div>
              <p class="text-white/65">Ingeniería, negocios o liderazgo.</p>
            </div>

            <div class="flex gap-3">
              <div class="w-2 h-2 rounded-full bg-[var(--primary)] mt-3"></div>
              <p class="text-white/65">Impacto directo en nuevas generaciones.</p>
            </div>

            <div class="flex gap-3">
              <div class="w-2 h-2 rounded-full bg-[var(--primary)] mt-3"></div>
              <p class="text-white/65">Participación flexible y significativa.</p>
            </div>

          </div>

          <div class="flex flex-wrap gap-4">

            <a
              href="https://forms.gle/TUFORMMENTORES"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary"
            >
              Aplicar como mentor(a)
            </a>

            <a
              href="mailto:contacto@ariasteamex.org"
              class="btn-secondary"
            >
              Contactar
            </a>

          </div>

        </div>

      </div>

    </section>

    <!-- WHAT YOU CAN JOIN -->
    <section class="container-site pb-28 reveal">

      <div class="rounded-3xl overflow-hidden border border-white/10">

        <div class="bg-gradient-to-r from-[#2c1f35] to-[#3d2b4a] p-10 md:p-14">

          <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-5">
            Áreas del equipo
          </p>

          <h2 class="text-5xl md:text-6xl leading-none mb-8 max-w-5xl">
            Hay espacio para distintos talentos
          </h2>

          <p class="text-white/72 text-lg max-w-3xl leading-relaxed">
            No todo es construir robots. Un gran equipo necesita muchas fortalezas.
          </p>

        </div>

        <div class="grid md:grid-cols-2 xl:grid-cols-4 bg-black/20">

          <div class="p-8 border-t border-white/10 xl:border-r">
            <p class="text-3xl mb-3">Técnica</p>
            <p class="text-white/60">
              Mecánica, code y electrónica.
            </p>
          </div>

          <div class="p-8 border-t border-white/10 xl:border-r">
            <p class="text-3xl mb-3">Creativa</p>
            <p class="text-white/60">
              Branding, media y contenido.
            </p>
          </div>

          <div class="p-8 border-t border-white/10 xl:border-r">
            <p class="text-3xl mb-3">Negocios</p>
            <p class="text-white/60">
              Sponsors, organización y estrategia.
            </p>
          </div>

          <div class="p-8 border-t border-white/10">
            <p class="text-3xl mb-3">Humana</p>
            <p class="text-white/60">
              Liderazgo, mentoría e impacto.
            </p>
          </div>

        </div>

      </div>

    </section>

    <!-- DIRECT CONTACT -->
    <section class="container-site pb-32 reveal">

      <div class="rounded-3xl p-10 md:p-14 bg-gradient-to-r from-[#2c1f35] to-[#3d2b4a] border border-white/10">

        <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4 reveal delay-1">
          Contacto directo
        </p>

        <h2 class="text-5xl md:text-6xl mb-6 leading-none reveal delay-2">
          ¿Tienes dudas?
        </h2>

        <p class="text-white/70 max-w-2xl mb-8 text-lg reveal delay-3">
          Escríbenos y te orientamos personalmente.
        </p>

        <div class="flex flex-wrap gap-4 reveal delay-4">

          <a
            href="https://wa.me/525564876703"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            WhatsApp
          </a>

          <a
            href="mailto:ariasteamex@gmail.com"
            class="btn-secondary"
          >
            Correo
          </a>

          <a
            href="https://instagram.com/aria.steamex"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary"
          >
            Instagram
          </a>

        </div>

      </div>

    </section>

  </main>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const items = document.querySelectorAll(".reveal");

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("show");
          }
        });
      }, { threshold: 0.15 });

      items.forEach((item) => observer.observe(item));
    });
  </script>

</BaseLayout>