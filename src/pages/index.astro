---
import BaseLayout from "../layouts/baselayout.astro";
import Navbar from "../components/navbar.astro";
import Hero from "../components/hero.astro";
---

<BaseLayout title="ARIA STEAMEX | Oficial">

  <Navbar />

  <main class="overflow-hidden">

    <!-- HERO -->
    <Hero />

    <!-- QUICK ACCESS GRID -->
    <section class="container-site pb-28 -mt-6">

      <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6">

        <!-- NOSOTRAS -->
        <a
          href="/nosotras"
          class="group glass rounded-3xl p-7 min-h-[240px] transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-purple-500/10 border border-white/5 hover:border-white/15 reveal"
        >
          <div class="flex justify-between items-start mb-10">
            <span class="text-xs tracking-[0.25em] text-white/45 uppercase">
              01
            </span>

            <span class="text-white/30 group-hover:text-white/70 transition">
              →
            </span>
          </div>

          <h2 class="text-4xl mb-4">Nosotras</h2>

          <p class="text-white/65 leading-relaxed">
            Conoce nuestra misión, visión, historia y liderazgo dentro de
            Project Steamex.
          </p>
        </a>

        <!-- FIRST -->
        <a
          href="/first"
          class="group glass rounded-3xl p-7 min-h-[240px] transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-purple-500/10 border border-white/5 hover:border-white/15 reveal"
        >
          <div class="flex justify-between items-start mb-10">
            <span class="text-xs tracking-[0.25em] text-white/45 uppercase">
              02
            </span>

            <span class="text-white/30 group-hover:text-white/70 transition">
              →
            </span>
          </div>

          <h2 class="text-4xl mb-4">FIRST / FRC</h2>

          <p class="text-white/65 leading-relaxed">
            Descubre la competencia de robótica juvenil más prestigiosa del
            mundo.
          </p>
        </a>

		        <!-- IMPACTO -->
        <a
          href="/impacto"
          class="group glass rounded-3xl p-7 min-h-[240px] transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-purple-500/10 border border-white/5 hover:border-white/15 reveal"
        >
          <div class="flex justify-between items-start mb-10">
            <span class="text-xs tracking-[0.25em] text-white/70 uppercase">
              03
            </span>

            <span class="text-white/70 group-hover:text-white transition">
              →
            </span>
          </div>

          <h2 class="text-4xl mb-4">Impacto</h2>

          <p class="text-white/70 leading-relaxed">
            Nuestro impacto en la comunidad y el desarrollo de talento femenil en STEM.
          </p>
        </a>

        <!-- UNIRSE -->
        <a
          href="/unirse"
          class="group glass rounded-3xl p-7 min-h-[240px] transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-purple-500/10 border border-white/5 hover:border-white/15 reveal"
        >
          <div class="flex justify-between items-start mb-10">
            <span class="text-xs tracking-[0.25em] text-white/45 uppercase">
              04
            </span>

            <span class="text-white/30 group-hover:text-white/70 transition">
              →
            </span>
          </div>

          <h2 class="text-4xl mb-4">Únete</h2>

          <p class="text-white/65 leading-relaxed">
            Reclutamiento por formulario, informe introductorio o invitación.
          </p>
        </a>



      </div>
    </section>

    <!-- IMPACT SECTION -->
    <section class="container-site pb-28 reveal">

      <div class="grid lg:grid-cols-2 gap-10 items-center">

        <div>
          <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4">
            Crecimiento
          </p>

          <h2 class="text-6xl leading-none mb-6">
            Ingeniería con propósito
          </h2>

          <p class="text-white/70 text-lg max-w-xl leading-relaxed">
            ARIA STEAMEX no solo compite. Forma líderes, desarrolla talento
            técnico y abre oportunidades reales para mujeres en STEM.
          </p>
        </div>

        <div class="grid grid-cols-2 gap-5">

          <div class="glass rounded-3xl p-6">
            <p class="text-5xl mb-2">FRC</p>
            <p class="text-white/60">Competencia internacional</p>
          </div>

          <div class="glass rounded-3xl p-6">
            <p class="text-5xl mb-2">100%</p>
            <p class="text-white/60">Acceso gratuito</p>
          </div>

          <div class="glass rounded-3xl p-6">
            <p class="text-5xl mb-2">CDMX</p>
            <p class="text-white/60">Base comunitaria</p>
          </div>

          <div class="glass rounded-3xl p-6">
            <p class="text-5xl mb-2">2025</p>
            <p class="text-white/60">Año de fundación</p>
          </div>

        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
<section class="container-site pb-32 reveal">

  <div class="rounded-3xl p-10 md:p-14 bg-gradient-to-r from-[#2c1f35] to-[#3d2b4a] border border-white/10">

    <p class="text-sm uppercase tracking-[0.25em] text-white/45 mb-4 reveal delay-1">
      Próximo paso
    </p>

    <h2 class="text-5xl md:text-6xl mb-6 leading-none reveal delay-2">
      Construyamos algo grande
    </h2>

    <p class="text-white/70 max-w-2xl mb-8 text-lg reveal delay-3">
      Si quieres unirte, colaborar, apoyar o conocer más sobre ARIA STEAMEX,
      este es el momento.
    </p>

    <div class="flex flex-wrap gap-4 reveal delay-4">

      <a href="/contacto" class="btn-primary">
        Contactar
      </a>

      <a href="/unirse" class="btn-secondary">
        Unirse
      </a>

    </div>

  </div>

</section>

  </main>
  <script is:inline>
document.addEventListener("DOMContentLoaded", () => {
  const items = document.querySelectorAll(".reveal");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("show");
        }
      });
    },
    {
      threshold: 0.15,
      rootMargin: "0px 0px -50px 0px"
    }
  );

  items.forEach((item) => observer.observe(item));
});
</script>

</BaseLayout>