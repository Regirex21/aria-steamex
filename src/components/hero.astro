---
import { brand } from "../config/brand";
---

<section class="container-site pt-24 pb-28 grid lg:grid-cols-2 gap-14 items-center relative overflow-hidden">

  <!-- ambient glow -->
  <div class="glow-orb w-56 h-56 bg-purple-400/20 top-10 right-20"></div>
  <div class="glow-orb w-40 h-40 bg-pink-300/10 bottom-10 left-10"></div>

  <!-- left side -->
  <div class="relative z-10 animate-left">

    <p class="text-sm uppercase tracking-[0.25em] text-white/60 mb-4">
      Project STEAMex • Ciudad de México
    </p>

    <h1 class="text-6xl md:text-8xl leading-none mb-6">
      ARIA
    </h1>

    <p class="text-xl text-white/75 max-w-xl mb-8 leading-relaxed">
      Equipo femenil de FIRST Robotics Competition que forma líderes,
      desarrolla profesionales y abre oportunidades STEAM para futuras ingenieras.
    </p>

    <div class="flex flex-wrap gap-4">
      <a href="/unirse" class="btn-primary">Únete</a>
      <a href="/contacto" class="btn-secondary">Contáctanos</a>
    </div>

    <div class="mt-10 flex gap-8 text-sm text-white/70 flex-wrap">
      <div>
        <strong class="text-white block text-lg">FRC</strong>
        Competencia global
      </div>

      <div>
        <strong class="text-white block text-lg">100%</strong>
        Gratuito
      </div>

      <div>
        <strong class="text-white block text-lg">Mujeres</strong>
        Liderando en STEAM
      </div>
    </div>

  </div>

  <!-- right side -->
  <div class="relative z-10 glass rounded-3xl p-8 min-h-[500px] flex items-center justify-center animate-right delay-2">

    <div class="text-center">
      <p class="text-white/50 mb-3">Visual Placeholder</p>

      <p class="text-4xl mb-4">
        foto / cad / robot
      </p>

      <p class="text-white/60">
        aquí irá imagen principal del equipo
      </p>
    </div>

  </div>

</section>